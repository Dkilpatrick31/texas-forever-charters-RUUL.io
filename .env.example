# ============================================================
# DATABASE
# Get a free PostgreSQL database from Supabase: https://supabase.com
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ============================================================
# NEXTAUTH v5
# Generate a secret: npx auth secret
# ============================================================
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# GOOGLE OAUTH
# Create credentials at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# ============================================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================================
# STRIPE
# Get keys from https://dashboard.stripe.com/test/apikeys
# ============================================================
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================================
# EMAIL (SMTP)
# Use Gmail with an App Password, or Resend / Postmark
# Gmail: https://support.google.com/accounts/answer/185833
# ============================================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="tx4evercharters@gmail.com"
SMTP_PASS="your-gmail-app-password"
